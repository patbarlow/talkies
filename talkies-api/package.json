{
  "name": "talkies-api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "db:create": "wrangler d1 create talkies",
    "db:migrate": "wrangler d1 execute talkies --local --file=./schema.sql",
    "db:migrate:remote": "wrangler d1 execute talkies --remote --file=./schema.sql",
    "db:studio": "wrangler d1 execute talkies --local --command='SELECT * FROM users'"
  },
  "dependencies": {
    "hono": "^4.6.14",
    "jose": "^5.9.6"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241218.0",
    "typescript": "^5.7.2",
    "wrangler": "^3.95.0"
  }
}
